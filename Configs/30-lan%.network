[Match]
Name=lan*

[Link]
RequiredForOnline=enslaved

[Network]
Bridge=br0
LLDP=yes
EmitLLDP=customer-bridge

[Bridge]
MulticastRouter=query
# Bring member ports up with unknown-multicast flooding already disabled, so
# the bridge is contained from boot rather than relying on mrpd to flip it
# (which raced the bridge bring-up). This is BR_MCAST_FLOOD and is independent
# of broadcast (BR_BCAST_FLOOD / the ff:ff ATU entry), so ARP still works.
MulticastFlood=no

# IEEE Std 1722.1 Table B.1 ADP and ACMP
[BridgeMDB]
MulticastGroupAddress=91:e0:f0:01:00:00

# IEEE Std 1722.1 Table B.1 Identification Notifications
[BridgeMDB]
MulticastGroupAddress=91:e0:f0:01:00:01

# IEEE Std 1722 Table B.4.1 MAAP frames
[BridgeMDB]
MulticastGroupAddress=91:e0:f0:00:ff:00
